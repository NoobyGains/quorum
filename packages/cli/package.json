{
  "name": "@quorum/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "quorum": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'lint not yet configured'",
    "dev": "tsc --build --watch"
  },
  "dependencies": {
    "@quorum/artifacts": "workspace:*",
    "@quorum/store": "workspace:*",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "typescript": "5.8.3",
    "vitest": "4.1.4"
  }
}
