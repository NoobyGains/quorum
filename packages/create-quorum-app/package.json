{
  "name": "create-quorum-app",
  "version": "0.0.0",
  "private": true,
  "description": "Scaffolder for new Quorum-for-Apps projects. Run via `npm create quorum-app my-thing`.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "create-quorum-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'lint not yet configured'",
    "dev": "tsc --build --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "20.17.6",
    "typescript": "5.8.3",
    "vitest": "4.1.4"
  }
}
